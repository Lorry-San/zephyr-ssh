  *
  * @return 0 on success, otherwise a Win32 error code
  */
+static void zephyr_write_h264(const BYTE* data, UINT32 length)
+{
+	static HANDLE pipe = INVALID_HANDLE_VALUE;
+	static BOOL initialized = FALSE;
+	DWORD written = 0;
+	DWORD size;
+	char target[MAX_PATH];
+
+	if (!data || length == 0)
+		return;
+
+	if (!initialized)
+	{
+		initialized = TRUE;
+		size = GetEnvironmentVariableA("ZEPHYR_RDP_H264_PIPE", target, sizeof(target));
+		if ((size > 0) && (size < sizeof(target)))
+			pipe = CreateFileA(target, GENERIC_WRITE, FILE_SHARE_READ | FILE_SHARE_WRITE, NULL,
+			                   OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
+	}
+
+	if (pipe == INVALID_HANDLE_VALUE)
+		return;
+
+	if (!WriteFile(pipe, data, length, &written, NULL) || written != length)
+	{
+		CloseHandle(pipe);
+		pipe = INVALID_HANDLE_VALUE;
+	}
+}
